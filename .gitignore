# macOS
.DS_Store

# Real backend configs carry the account-id-bearing bucket name; commit only
# the *.example templates. (*.tfvars are already ignored below.)
backend.hcl

# Distilled one-shot diagnostic helpers extracted from agent sessions (a learning
# artifact / future toolset, not a deliverable). See scratch-tools/README.md.
scratch-tools/

# Machine-local Claude Code permissions — the auto-accumulated allow-list embeds
# account-bearing command literals (account id, state-bucket name). Keep it local;
# the curated, secret-free .claude/settings.json IS committed (shared read-only allows).
.claude/settings.local.json

# Fetched admin kubeconfig(s) — contain client certs/keys. Generated by the
# Ansible kubernetes role; never commit.
ansible/.kube/

# Local .terraform directories
.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version
# control as they are data points which are potentially sensitive and subject
# to change depending on the environment.
*.tfvars
*.tfvars.json

# EXCEPTION (model B): committed per-env stack inputs — non-secret CIDRs/flags, the
# reviewable env definitions. Rendered secret/account-bearing tfvars (e.g. 40-ecr
# credential ARNs) must use a DIFFERENT name (*.auto.tfvars) so they stay ignored.
!terraform/stack/aws/**/dev.tfvars
!terraform/stack/aws/**/prod.tfvars

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files created by terraform apply
.terraform.tfstate.lock.info

# Include override files you do wish to add to version control using negated pattern
# !example_override.tf

# Saved plan files (tofu plan -out=…): can embed resolved variable values
# (e.g. the account-id-bearing bucket name). Never commit them.
*.tfplan
*tfplan*

# GitOps secrets: the real ArgoCD repo deploy-key Secret carries an SSH private
# key — never commit it. Only the *.example template is checked in.
gitops/bootstrap/repo-deploy-key.yaml
# Generated SSH deploy keys (kept out of git regardless of location).
*_deploy_key
*_deploy_key.pub

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Optional: ignore graph output files generated by `terraform graph`
# *.dot

# Optional: ignore plan files saved before destroying Terraform configuration
# Uncomment the line below if you want to ignore planout files.
# planout
