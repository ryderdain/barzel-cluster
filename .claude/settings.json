{
  "permissions": {
    "allow": [
      "Bash(command -v hadolint)",
      "Bash(docker run *)",
      "Bash(kubectl get *)",
      "Bash(kubectl describe *)",
      "Bash(kubectl logs *)",
      "Bash(kubectl auth *)",
      "Bash(kubectl config *)",
      "Bash(kubectl top *)",
      "Bash(shellcheck *)",
      "Bash(hadolint *)",
      "Bash(tofu plan *)",
      "Bash(tofu show *)",
      "Bash(tofu validate *)",
      "Bash(tofu state list *)",
      "Bash(helm list *)",
      "Bash(helm status *)",
      "Bash(helm show *)",
      "Bash(helm get *)",
      "Bash(aws sts get-caller-identity *)",
      "Bash(aws ec2 describe-*)",
      "Bash(aws ssm get-parameter *)",
      "Bash(aws s3 ls *)",
      "Bash(aws ssm get-* *)",
      "Bash(aws ssm describe-* *)",
      "Bash(aws ecr describe-* *)",
      "Bash(aws kms describe-* *)",
      "Bash(aws kms list-* *)",
      "Bash(aws secretsmanager list-* *)",
      "Bash(aws iam list-* *)",
      "Bash(aws configure list-profiles)",
      "Bash(tofu fmt -check *)",
      "Bash(tofu output *)",
      "Bash(tofu output)",
      "Bash(tofu validate)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '=== aroni: live state (SCRATCHPAD current focus) ==='; awk '/^## Current focus/,/^## Open considerations/' SCRATCHPAD.md 2>/dev/null | head -40; echo '--- aroni vault, last passes ---'; git -C ../aroni log --oneline -3 2>/dev/null || echo '(aroni vault not found at ../aroni - see CLAUDE.md aroni anchor)'"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'aroni reminder: before this window is summarized, flush live working state into SCRATCHPAD.md (## Current focus) so the next context rehydrates faithfully; the summary is not guaranteed to preserve it.'"
          }
        ]
      }
    ]
  }
}
