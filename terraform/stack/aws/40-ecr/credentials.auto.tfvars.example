# Template — the secrets phase renders the real `credentials.auto.tfvars` (gitignored,
# auto-loaded) next to this file from gitops/bootstrap/create_pullthrough_secrets.sh.
# Account-level Secrets Manager ARNs, SHARED across dev/prod (one token each); never
# committed. quay.io needs NO credential (ECR treats it as credential-free).
#
#   ghcr_credential_arn      = "arn:aws:secretsmanager:<region>:<account>:secret:ecr-pullthroughcache/brzl-<env>-github-XXXXXX"
#   dockerhub_credential_arn = "arn:aws:secretsmanager:<region>:<account>:secret:ecr-pullthroughcache/brzl-<env>-dockerhub-XXXXXX"
