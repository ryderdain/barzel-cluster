# Copy to terraform.tfvars (gitignored) ONLY if you prefer files over TF_VAR_*.
# The node SSH key pair is now generated by OpenTofu (see secrets.tf) — there is
# no public key to supply and the private key never enters git.
#
# Everything here is optional (sensible defaults in variables.tf). The state bucket
# used to read the lower layers is now DERIVED from your account id at runtime
# (remote_state.tf) — no TF_VAR_state_bucket to export. You only need ../backend.hcl
# in place (copied once from backend.hcl.example) for this layer's own backend.
#
# instance_type = "m6g.large"   # cheaper lever: "m6g.medium"
# capacity_type = "spot"        # iteration default; "on-demand" for the demo
